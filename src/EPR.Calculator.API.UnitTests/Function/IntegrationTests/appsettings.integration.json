{
  "AllowedHosts": "*",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "ClientId": "ClientId",
    "TenantId": "TenantId"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=.;Initial Catalog=PayCal;Integrated Security=True;TrustServerCertificate=True"
  },
  "ApplicationInsights": {
    "ConnectionString": "Copy connection string from Application Insights Resource Overview"
  },
  "BlobStorage": {
    "ResultFileCSVContainerName": "paycal",
    "BillingFileCSVContainerName": "paycal-billingfilecsv",
    "BillingFileJsonContainerName": "paycal-billingfilejson",
    "BillingFileJsonForFssContainerName": "paycal-billingfilejsonauthorisedforfss",
    "ConnectionString": ""
  },
  "Timeouts": {
    "RpdStatus": 1,
    "RpdStatusCommand": 1,
    "PrepareCalcResults": 1,
    "PrepareCalcResultsCommand": 1,
    "Transpose": 1,
    "TransposeCommand": 1
  },

  "AzureWebJobsStorage": "UseDevelopmentStorage=true",

  "Serilog": {
    "MinimumLevel": {
      "Default": "Error",
      "Override": {
        "EPR.Calculator": "Debug"
      }
    }
  },

  "CommonDataApi": {
    "DataLoader": {
      "Enabled": true,
      "PomBatchSize": 100,
      "OrganisationBatchSize": 100
    },

    "HttpClient": {
      "BaseUrl": "http://localhost",
      "CompressionEnabled": false,
      "StreamStartTimeout": "00:00:30"
    }
  },

  "Database": {
    "ConnectionString": "",
    "CommandTimeout": "00:05:00"
  }
}