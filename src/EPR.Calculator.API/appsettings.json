{
  "AllowedHosts": "*",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "ClientId": "ClientId",
    "TenantId": "TenantId"
  },
  "ApplicationInsights": {
    "ConnectionString": "Copy connection string from Application Insights Resource Overview"
  },
  "BlobStorage": {
    "ResultFileCSVContainerName": "paycal",
    "BillingFileCSVContainerName": "paycal-billingfilecsv",
    "BillingFileJsonContainerName": "paycal-billingfilejson",
    "BillingFileJsonForFssContainerName": "paycal-billingfilejsonauthorisedforfss",
    "ConnectionString": ""
  },

  "Logging": {
    "LogLevel": {
      "Default"                  : "Information",
      "EPR.Calculator"           : "Debug",
      "EntityFrameworkCore"      : "Warning",
      "IdentityModel"            : "Warning",
      "AspNetCore.Authentication": "Warning"
    }
  },

  "Serilog:MinimumLevel"                                             : "Information",
  "Serilog:MinimumLevel:Override:EPR.Calculator"                     : "Debug",
  "Serilog:MinimumLevel:Override:Microsoft.EntityFrameworkCore"      : "Warning",
  "Serilog:MinimumLevel:Override:Microsoft.IdentityModel"            : "Warning",
  "Serilog:MinimumLevel:Override:Microsoft.AspNetCore.Authentication": "Warning",

  "CommonDataApi:DataLoader:Enabled": true,
  "CommonDataApi:HttpClient:BaseUrl": "https://localhost:5001",
  "CommonDataApi:DataLoader:PomBatchSize": 10000,
  "CommonDataApi:DataLoader:OrganisationBatchSize": 10000,

  "CommonDataApi:HttpClient:CompressionEnabled": true,
  "CommonDataApi:HttpClient:StreamStartTimeout": "00:15:00",

  "Database:ConnectionString": "Data Source=.;Initial Catalog=PayCal;Integrated Security=True;TrustServerCertificate=True",
  "Database:CommandTimeout": "00:15:00"

}
